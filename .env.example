# Public site URL (used for canonical URLs, sitemap, Open Graph, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://copypaste3d.pl

# Form backend — create a form at https://formspree.io and paste the endpoint,
# e.g. https://formspree.io/f/abcdwxyz
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Analytics — set exactly ONE of these (or neither to disable analytics)
# Plausible: your site domain as registered in Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
